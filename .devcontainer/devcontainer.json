{
    "name": "powston-simulator",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter"
            ]
        }
    },
    "remoteEnv": {
        "POWSTON_API_KEY": "${localEnv:POWSTON_API_KEY}",
        "POWSTON_API_BASE": "https://app.powston.com"
    }
}
